# --- Hersafety Environment Variables Template ---
# Copy this file to .env and fill in your actual credentials

# Server Configuration
PORT=5000

# MongoDB Database URL
MONGODB_URI=your_mongodb_connection_string_here

# Razorpay Keys (Payment Integration)
RZP_KEY_ID=your_razorpay_key_id_here
RZP_KEY_SECRET=your_razorpay_secret_here

# Google OAuth Client ID
G_CLIENT_ID=your_google_client_id_here

# Google Gemini AI Key
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Twilio Credentials (SMS Alerts)
TWILIO_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=your_twilio_phone_number_here

# AWS S3 (Secure Storage)
AWS_ACCESS_KEY=your_aws_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=hersafety-vault
AWS_REGION=us-east-1

# Redis (Optional: Task Queue)
# REDIS_URL=redis://127.0.0.1:6379
